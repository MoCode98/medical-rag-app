# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-llm:7b-chat
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Paths Configuration
PDF_FOLDER=./pdfs  # Folder containing PDF files to process
DATA_FOLDER=./data  # Output folder for processed data

# Vector Database Configuration
VECTOR_DB_PATH=./vector_db
VECTOR_DB_TYPE=chroma  # Options: chroma, qdrant

# Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100

# RAG Configuration
TOP_K_RESULTS=5
TEMPERATURE=0.1
MAX_TOKENS=2048

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_pipeline.log

# Enhanced PDF Parsing Limits
MAX_FIGURES_PER_PAGE=20
MAX_CONTENT_FOR_REFERENCES=100000
MAX_REFERENCES_TO_EXTRACT=200
FIGURE_CAPTION_SEARCH_DISTANCE=50

# Re-ranking Settings
RERANK_CHUNK_TRUNCATION=500
DEFAULT_RELEVANCE_SCORE=0.5

# Embedding Settings
NOMIC_EMBED_DIMENSIONS=768
CONNECTION_TIMEOUT=5.0

# Metadata Extraction
METADATA_CHECK_CHARS=1000

# LLM Timeouts (in seconds)
LLM_TIMEOUT_GENERATION=120.0
LLM_TIMEOUT_RERANKING=60.0
LLM_TIMEOUT_EXPANSION=60.0
LLM_TIMEOUT_CLASSIFICATION=30.0
