# Docker ignore file - keeps image size minimal

# Version control
.git/
.gitignore
.gitattributes

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store
Thumbs.db

# Development and testing
.env.local
.env.test
*.log
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Linter and formatter cache
.ruff_cache/
.mypy_cache/
.black_cache/

# Data directories (mounted as volumes)
pdfs/
vector_db/
data/
logs/

# Documentation (optional - include if needed in container)
*.md
!README.md
docs/

# Test files
tests/
test_*.py
*_test.py

# Notebooks
*.ipynb
.ipynb_checkpoints/

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Docker files (don't copy into image)
Dockerfile
docker-compose.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Large or unnecessary files
*.zip
*.tar.gz
*.rar
*.7z
*.dmg
*.iso
