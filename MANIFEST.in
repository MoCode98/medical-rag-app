# Include documentation
include README.md
include QUICKSTART.md
include INSTALLATION.md
include IMPROVEMENTS.md
include V2.1_FEATURES.md
include COMPLETE_IMPLEMENTATION_SUMMARY.md
include WHATS_NEW.md
include LICENSE

# Include configuration files
include .env.example
include Modelfile.example
include requirements.txt
include requirements-lock.txt

# Exclude unnecessary files
exclude .DS_Store
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude * .pytest_cache
recursive-exclude * *.egg-info

# Exclude data directories
recursive-exclude pdfs *
recursive-exclude data *
recursive-exclude logs *
recursive-exclude chroma_db *
